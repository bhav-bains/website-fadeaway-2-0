---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import PillarsSection from "../components/PillarsSection.astro";
import AgitatorSection from "../components/AgitatorSection.astro";
import PackagesSection from "../components/PackagesSection.astro";
import TestimonialSection from "../components/TestimonialSection.astro";
import StepsGridSection from "../components/StepsGridSection.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import ProjectShowcase from "../components/ProjectShowcase.astro";
import ROISection from "../components/ROISection.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import highPerformanceWebsiteImg from "../assets/high-performance-website.png"; // Placeholder for OG
import websiteDesignHeroImg from "../assets/website-design-background-image-hero.png";
import fadeawayCreativesImg from "../assets/image-fadeaway-creatives.png";
import fcWebPillar2 from "../assets/FC-web-pillar-2.png";
import fcWebPillar3 from "../assets/FC-web-pillar-3.png";
import sportsSidelineImg from "../assets/sports-sideline.png";

const features = [
    {
        title: "Core Web Vitals Optimization",
        description:
            "We guarantee passing scores on Google’s strict performance metrics for LCP, FID, and CLS.",
    },
    {
        title: "SSL/TLS Encryption Certificate",
        description:
            "Standardized security protocols to protect visitor data and establish trust.",
    },
    {
        title: "Global CDN Propagation",
        description:
            "Content Delivery Network integration to serve your site assets from the server closest to your user.",
    },
    {
        title: "Automatic Cache Invalidation",
        description:
            "Ensuring users always see the latest version of your site without manual refreshing.",
    },
    {
        title: "Responsive Viewport Configuration",
        description:
            "Fluid layouts that adapt pixel-perfectly to mobile, tablet, and desktop breakpoints.",
    },
    {
        title: "Semantic HTML5 Architecture",
        description:
            "Clean code structure that helps search engine crawlers index your content accurately.",
    },
    {
        title: "Image Optimization & WebP Conversion",
        description:
            "Next-gen image formatting to reduce payload size without sacrificing quality.",
    },
    {
        title: "Uptime Monitoring & Alerts",
        description:
            "24/7 automated surveillance to ensure your digital storefront never goes dark.",
    },
    {
        title: "Server-Side Security Patching",
        description:
            "Proactive defense against vulnerabilities and malicious traffic spikes.",
    },
    {
        title: "Schema Markup Implementation",
        description:
            "Structured data integration to help rich snippets appear in search results.",
    },
    {
        title: "Monthly Analytics Reporting",
        description:
            "Transparent data regarding traffic sources, bounce rates, and user acquisition.",
    },
    {
        title: "Content Management Support",
        description:
            "Regular content updates handled by our team so you never touch a line of code.",
    },
];

const pillars = [
    {
        title: "Elite User Experience",
        copy: "First impressions matter. We deploy a sub-3-click mobile checkout that syncs directly with Mindbody, Jane App, or your clinical calendar, guiding patients from 'just looking' to 'booked' with zero friction.",
        image: fadeawayCreativesImg,
    },
    {
        title: "SEO for Local Dominance",
        copy: "Most clinics are buried on page 3. We optimize your Google Business Profile so you rank #1 when clients search for physio, pilates, or wellness treatments in your city.",
        image: fcWebPillar2,
    },
    {
        title: "Built for the Practice",
        copy: 'Your practice evolves, and your site should too. From clear "Patient Pathways" to complex scheduling and intake forms, our architecture handles it all seamlessly.',
        image: fcWebPillar3,
    },
];
---

<Layout
    title="High-Performance Websites for Wellness & Fitness | Fadeaway Creatives"
    description="Dominate your local market with an SEO-first website built for wellness studios, gyms, yoga, and fitness brands."
    ogImage={highPerformanceWebsiteImg.src}
>
    <Header />

    <main>
        {/* 01. Hero Section */}
        <Hero
            title="Dominate Local Search.<br />Fully Book Your Schedule."
            subtitle="Stop treating your website like a digital brochure. We build high-converting, mobile-first booking engines strictly for boutique fitness studios and wellness clinics. Scale your practice and pack your classes."
            ctaText="Get Your Custom Demo"
            ctaLink="/contact"
            cta2Text="View Packages"
            cta2Link="#pricing"
            badgeText="Wellness & Boutique Fitness Growth"
            backgroundImage={websiteDesignHeroImg}
        />

        {/* 02. The Sideline Reality Check (Agitator) */}
        <AgitatorSection
            punchline="You aren't just losing website clicks.<br />You are losing high-LTV patients to the clinic down the street because their mobile booking is easier to use."
            backgroundImage={sportsSidelineImg}
        />

        <PillarsSection
            title="The Practice Growth Blueprint"
            pillars={pillars}
        />

        {/* 05. Packages / Pricing */}
        <PackagesSection
            eyebrow="PRICING"
            title={`Simple, Transparent <span class="text-fadeaway-teal">Packages</span>`}
            subtitle="No hourly billing. No custom quote games. Just high-performance digital engines designed to pack your facility."
            packages={[
                {
                    name: "Attract",
                    price: "$499",
                    period: "/month",
                    setup: "$999 one-time website build setup",
                    description:
                        "For wellness studios and clinics ready to turn mobile traffic into booked appointments.",
                    includesSubtext:
                        "Includes a Smart Website and SEO Growth services.",
                    features: [
                        "Hosting, SSL, backups, uptime monitoring",
                        "High-speed, mobile-first SEO-ready website build",
                        "Direct clinical calendar sync (Jane / Mindbody)",
                        "Patient Pathway UI/UX design",
                        "Google Business Profile (Map Pack) setup",
                        "Live SEO dashboard",
                        "SEO campaigns (keyword tracking, blog posts, Google Business Profile optimization)",
                    ],
                    tagline:
                        "Attract more clients every single month. Stop losing patients to a competitor with a better booking experience.",
                    ctaText: "See the demo",
                    ctaLink: "/contact",
                    highlighted: true,
                },
                {
                    name: "Growth",
                    price: "$999",
                    period: "/month",
                    setup: "$999 one-time website build setup",
                    description:
                        "For established practices ready to dominate local search and scale rapidly.",
                    includesSubtext:
                        "Includes a Smart Website, SEO Growth & Lead Generation services.",
                    features: [
                        "Everything in the Attract package",
                        "Weekly strategy calls",
                        "Advanced lead generation campaigns",
                        "Paid ad management (Google & Meta)",
                        "Hyper-local neighborhood SEO landing pages",
                        "Social media campaign support",
                        "Advanced booking & direct-attribution analytics",
                        "Automated patient review request system",
                    ],
                    tagline:
                        "Scale appointments and fully book your practice on autopilot.",
                    ctaText: "See the demo",
                    ctaLink: "/contact",
                },
            ]}
        >
            <div
                slot="footer"
                class="mt-8 md:mt-12 text-center max-w-2xl mx-auto glass-effect border-white/5 py-4 px-6 md:py-6 rounded-2xl relative overflow-hidden group hover:border-white/10 transition-colors"
            >
                <div
                    class="absolute inset-0 bg-gradient-to-r from-fadeaway-teal/5 to-fadeaway-orange/5 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"
                >
                </div>

                <p
                    class="text-neutral-400 text-sm md:text-base leading-relaxed relative z-10"
                >
                    Need something completely custom? We make custom <span
                        class="text-neutral-200 font-medium whitespace-nowrap"
                        >websites</span
                    > and <span
                        class="text-fadeaway-teal font-medium whitespace-nowrap"
                        >automations</span
                    > to bring your ideas to reality. <a
                        href="/contact"
                        class="text-fadeaway-orange hover:text-white transition-colors underline decoration-fadeaway-orange/30 hover:decoration-fadeaway-orange underline-offset-4 ml-1 whitespace-nowrap"
                        >Let's connect.</a
                    >
                </p>
            </div>
        </PackagesSection>

        <TestimonialSection
            testimonials={[
                {
                    headline: "Our schedule filled up in the first month.",
                    quote: "Before Fadeaway, clients were calling us to book because the online system was impossible on a phone. The new site syncs directly with our Jane App calendar. Now 90% of our bookings come in overnight with zero admin work. It's completely changed how we operate.",
                    author: "[Name]",
                    role: "Owner at [Pilates Studio]",
                    stars: 5,
                },
                {
                    headline: "We went from page 3 to the Map Pack.",
                    quote: "We'd been invisible on Google for years. After Fadeaway overhauled our Google Business Profile and local SEO, we now rank in the top 3 for 'physiotherapy near me' in our area. New patient inquiries have nearly doubled in under 90 days.",
                    author: "[Name]",
                    role: "Clinic Director at [Physio Clinic]",
                    stars: 5,
                },
                {
                    headline: "Finally a team that understands wellness brands.",
                    quote: "Every other agency wanted to build a generic template. Fadeaway actually understood the Patient Pathway — intake, booking, trust-building. The result is a site that converts visitors into booked consultations. I focus on my clients now, not fixing broken web pages.",
                    author: "[Name]",
                    role: "Founder at [Wellness Clinic]",
                    stars: 5,
                },
            ]}
        />

        {/* 06. 6-Step SEO & AI Process */}
        <StepsGridSection
            title="How We Help Dominate Local & AI Search."
            subtitle="Most academies are completely invisible online. We use a multi-step system to make sure you are the #1 recommendation on Google and modern AI search engines."
            steps={[
                {
                    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>',
                    title: "Win the Google Map Pack",
                    copy: "We optimize your Google Business Profile so your studio shows up first on the map when clients search for local classes or wellness treatments in your area.",
                },
                {
                    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z" /></svg>',
                    title: "Target Surrounding Neighborhoods",
                    copy: "Clients don't just search your city; they search their specific suburbs. We build pages dedicated to capturing traffic from your entire local area, not just your zip code.",
                },
                {
                    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" /></svg>',
                    title: "Be the AI's Top Recommendation",
                    copy: "Clients are starting to ask ChatGPT and Google's AI for wellness recommendations. We structure your site's data so that when they ask an AI for the \"best pilates studio near me,\" your practice is the top answer.",
                },
                {
                    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" /></svg>',
                    title: "Automated 5-Star Reviews",
                    copy: "Google and AI bots both heavily favor businesses with fresh, glowing reviews. We set up automated text and email reminders to capture these from clients right after a great session.",
                },
                {
                    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>',
                    title: "Lightning-Fast Speeds",
                    copy: "Search engines penalize slow websites. We build your site to load in under a second, giving you a perfect performance score and pushing you to the top of the search results.",
                },
                {
                    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" /></svg>',
                    title: "Track Real Booked Appointments",
                    copy: 'We don’t care about useless "website views." We track exactly which Google or AI searches actually led to a booked appointment or a completed consultation.',
                },
            ]}
        />

        {
            /* 05. The Solution: Why Astro? — HIDDEN
        <PillarsSection
            title="Modern Tech for an Active World"
            pillars={[
                {
                    title: "Lightning Fast Mobile Loads",
                    copy: "Aastro components serve zero hydration JS by default. Your site loads in milliseconds, capturing parents' attention before they look back at the field.",
                    image: fcWebPillar2,
                },
                {
                    title: "SEO-First Architecture",
                    copy: "Clean HTML structure and automated sitemaps ensure you're at the top of Google when a parent searches for local clubs.",
                    image: fcWebPillar3,
                },
                {
                    title: "Roster Management Ready",
                    copy: "Seamless integration with registration platforms or custom tournament filters. built to grow with your program.",
                    image: fadeawayCreativesImg,
                }
            ]}
        />
        */
        }

        {
            /* 05. Features Grid — HIDDEN
        <FeatureGrid
            title="Enterprise-Grade Tech Included Standard"
            subtitle="Why pay thousands for a custom build? We include all of this in our standard maintenance plans."
            features={features}
        />
        */
        }

        {
            /* 06. Social Proof / Demo Showcase — HIDDEN
        <ProjectShowcase
            projects={[
                { title: "MetroStars Academy Performance Build" },
                { title: "Elite Performance Training Demo" },
            ]}
        />
        */
        }

        {/* 07. Closing / ROI Section */}
        <ROISection
            title="Build the Digital Engine Your Practice Deserves."
            description="Stop letting bad tech slow down your growth. Let’s build a frictionless, 24/7 digital front desk that fills your schedule."
            ctaText="Book a Growth Call"
            ctaLink="/contact"
        />
    </main>
    <Footer />
</Layout>


