---
import Layout from "../layouts/Layout.astro";
import { Header } from "../components/Header";
import { Footer } from "../components/Footer";
import { Button } from "../components/Button";
import { Badge } from "../components/Badge";
---

<Layout title="Request Your Free Demo Website - Fadeaway Creatives">
    <Header client:load />

    <main class="pt-24 min-h-screen">
        <section class="section-padding">
            <div class="container-max max-w-2xl mx-auto">
                <div class="text-center mb-10 animate-fade-in">
                    <Badge variant="primary">
                        <span>Free Demo Build</span>
                    </Badge>
                    <h1
                        class="text-4xl md:text-5xl font-outfit font-bold mt-4 mb-4"
                    >
                        See Your Brand <span class="text-fadeaway-teal"
                            >Come to Life</span
                        >
                    </h1>
                    <p class="text-lg text-neutral-300">
                        We'll build a custom homepage demo for your business to
                        show you what's possible — no cost, no commitment.
                    </p>
                </div>

                <div
                    class="glass-effect p-6 md:p-8 rounded-2xl animate-slide-up"
                >
                    <form
                        name="demo-request"
                        method="POST"
                        action="/demo-success"
                        data-netlify="true"
                        class="space-y-4"
                    >
                        <div class="space-y-4">
                            <div>
                                <label
                                    for="name"
                                    class="block text-sm font-medium text-neutral-300 mb-1"
                                >
                                    Your Name
                                </label>
                                <input
                                    type="text"
                                    name="name"
                                    id="name"
                                    required
                                    placeholder="John Doe"
                                    class="input-primary"
                                />
                            </div>

                            <div>
                                <label
                                    for="email"
                                    class="block text-sm font-medium text-neutral-300 mb-1"
                                >
                                    Email Address
                                </label>
                                <input
                                    type="email"
                                    name="email"
                                    id="email"
                                    required
                                    placeholder="john@example.com"
                                    class="input-primary"
                                />
                            </div>

                            <div>
                                <label
                                    for="business"
                                    class="block text-sm font-medium text-neutral-300 mb-1"
                                >
                                    Business Name / Website
                                </label>
                                <input
                                    type="text"
                                    name="business"
                                    id="business"
                                    required
                                    placeholder="My Awesome Business"
                                    class="input-primary"
                                />
                            </div>

                            <div>
                                <label
                                    for="vision"
                                    class="block text-sm font-medium text-neutral-300 mb-1"
                                >
                                    Design Preferences (Optional)
                                </label>
                                <textarea
                                    name="vision"
                                    id="vision"
                                    placeholder="I like modern, dark themes. My competitors are..."
                                    class="input-primary min-h-[100px] resize-none"
                                ></textarea>
                            </div>

                            <div class="pt-2">
                                <Button
                                    variant="primary"
                                    size="lg"
                                    className="w-full"
                                    type="submit"
                                >
                                    Build My Free Demo
                                </Button>
                                <p
                                    class="text-xs text-center text-neutral-500 mt-3"
                                >
                                    You'll receive a video walkthrough of your
                                    demo in 2-3 days.
                                </p>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Layout>
