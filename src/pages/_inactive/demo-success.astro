---
import Layout from "../layouts/Layout.astro";
import { Header } from "../components/Header";
import { Footer } from "../components/Footer";
import { Button } from "../components/Button";
import { Badge } from "../components/Badge";
---

<Layout title="Demo Requested - Fadeaway Creatives">
    <Header client:load />

    <main class="pt-24 min-h-screen flex items-center justify-center">
        <section class="section-padding mb-24">
            <div class="container-max max-w-2xl mx-auto text-center">
                <div
                    class="glass-effect p-8 md:p-12 rounded-2xl animate-fade-in"
                >
                    <div class="text-6xl mb-6">🚀</div>

                    <h1 class="text-3xl md:text-4xl font-outfit font-bold mb-4">
                        We're Starting Your Engines!
                    </h1>

                    <p
                        class="text-lg text-neutral-300 mb-8 max-w-lg mx-auto leading-relaxed"
                    >
                        Your request is in. We'll start crafting a custom
                        homepage concept for your brand.
                        <br /><br />
                        Expect a personal email from us within 48 hours with a link
                        to your private demo.
                    </p>

                    <a href="/">
                        <Button variant="secondary" size="lg">
                            Return Home
                        </Button>
                    </a>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Layout>
