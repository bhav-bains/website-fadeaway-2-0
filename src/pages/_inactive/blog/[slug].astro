---
import Layout from '../../layouts/Layout.astro';
import { Header } from '../../components/Header';
import { Footer } from '../../components/Footer';
import { Card } from '../../components/Card';
import { Badge } from '../../components/Badge';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((post) => post.slug !== entry.slug && post.data.tags.some((tag) => entry.data.tags.includes(tag)))
  .slice(0, 3);
---

<Layout title={`${entry.data.title} - Blog`} description={entry.data.description}>
  <Header client:load />

  <main>
    <article class="section-padding border-t border-white/5">
      <div class="container-max">
        <div class="max-w-3xl mx-auto">
          <div class="mb-8">
            <a href="/blog" class="text-fadeaway-orange hover:text-fadeaway-teal transition-colors text-sm font-medium">
              ← Back to Blog
            </a>
          </div>

          <header class="mb-12">
            <div class="flex gap-2 mb-4 flex-wrap">
              {entry.data.tags.map((tag) => (
                <Badge client:load variant="primary">
                  {tag}
                </Badge>
              ))}
            </div>

            <h1 class="text-5xl md:text-6xl font-outfit font-bold mb-4">
              {entry.data.title}
            </h1>

            <p class="text-lg text-neutral-300 mb-6">
              {entry.data.description}
            </p>

            <div class="flex flex-col md:flex-row md:items-center gap-4 text-sm text-neutral-400 pb-6 border-b border-white/5">
              <span>By {entry.data.author}</span>
              <span>•</span>
              <span>{entry.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              <span>•</span>
              <span id="readTime">5 min read</span>
            </div>
          </header>

          <div class="prose prose-invert max-w-none mb-12">
            <Content />
          </div>

          {relatedPosts.length > 0 && (
            <section class="mt-16 pt-12 border-t border-white/5">
              <h2 class="text-3xl font-outfit font-bold mb-8">Related Articles</h2>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                {relatedPosts.map((post) => (
                  <a href={`/blog/${post.slug}`} class="group">
                    <Card client:load variant="glass">
                      <div class="mb-3">
                        <Badge client:load variant="primary">
                          {post.data.tags[0] || 'Article'}
                        </Badge>
                      </div>
                      <h3 class="text-lg font-outfit font-semibold mb-2 group-hover:text-fadeaway-orange transition-colors line-clamp-2">
                        {post.data.title}
                      </h3>
                      <p class="text-neutral-400 text-sm line-clamp-2">
                        {post.data.description}
                      </p>
                    </Card>
                  </a>
                ))}
              </div>
            </section>
          )}
        </div>
      </div>
    </article>
  </main>

  <Footer client:load />
</Layout>

<style is:global>
  .prose {
    --tw-prose-body: rgb(209, 213, 219);
    --tw-prose-headings: rgb(249, 250, 251);
    --tw-prose-lead: rgb(209, 213, 219);
    --tw-prose-links: rgb(255, 107, 53);
    --tw-prose-bold: rgb(249, 250, 251);
    --tw-prose-counters: rgb(156, 163, 175);
    --tw-prose-bullets: rgb(75, 85, 99);
    --tw-prose-hr: rgb(31, 41, 55);
    --tw-prose-quotes: rgb(209, 213, 219);
    --tw-prose-quote-borders: rgb(75, 85, 99);
    --tw-prose-captions: rgb(156, 163, 175);
    --tw-prose-code: rgb(249, 250, 251);
    --tw-prose-pre-code: rgb(209, 213, 219);
    --tw-prose-pre-bg: rgb(17, 24, 39);
    --tw-prose-th-borders: rgb(75, 85, 99);
    --tw-prose-td-borders: rgb(55, 65, 81);
  }

  .prose h2 {
    @apply text-3xl font-outfit font-bold mt-10 mb-4;
  }

  .prose h3 {
    @apply text-2xl font-outfit font-bold mt-8 mb-3;
  }

  .prose p {
    @apply text-neutral-300 mb-4 leading-relaxed;
  }

  .prose a {
    @apply text-fadeaway-orange hover:text-fadeaway-teal transition-colors;
  }

  .prose strong {
    @apply text-neutral-50 font-semibold;
  }

  .prose code {
    @apply bg-white/5 px-2 py-1 rounded text-fadeaway-orange;
  }

  .prose pre {
    @apply bg-fadeaway-darker/50 border border-white/5 rounded-lg p-4 overflow-x-auto mb-4;
  }

  .prose ul,
  .prose ol {
    @apply mb-4 ml-4;
  }

  .prose li {
    @apply mb-2 text-neutral-300;
  }

  .prose blockquote {
    @apply border-l-4 border-fadeaway-orange pl-4 py-1 italic text-neutral-400 mb-4;
  }
</style>
