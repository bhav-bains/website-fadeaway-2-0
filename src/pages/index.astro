---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Button from "../components/Button.astro";
import Badge from "../components/Badge.astro";
import { Image } from "astro:assets";
import logoImage from "../assets/fadeaway-logo-2.png";
import highPerformanceWebsiteImg from "../assets/high-performance-website.png";
import sportsMockupImg from "../assets/sports-website-mockup.png";
import wellnessMockupImg from "../assets/wellness-website-mockup.png";
import StepsGridSection from "../components/StepsGridSection.astro";
import ROISection from "../components/ROISection.astro";
---

<Layout
    title="Fadeaway Creatives | SEO Websites for Sports & Wellness Brands"
    description="We build high-converting, SEO-first websites for sports academies and wellness studios. Get found on Google, fill your schedule, and scale your business."
    ogImage={highPerformanceWebsiteImg.src}
>
    <Header />

    <main>
        {/* ── 01. HERO ── */}
        <section
            id="hero"
            class="relative min-h-screen flex items-center justify-center overflow-hidden bg-fadeaway-graphite px-4 md:px-8 py-16 md:py-24"
        >
            {/* ── BACKGROUND LAYER ── */}
            <div class="hero-bg-layer" aria-hidden="true">
                {/* Orange glow orb — center */}
                <div class="hero-glow hero-glow--orange"></div>
                {/* Teal glow orb — right */}
                <div class="hero-glow hero-glow--teal"></div>

                {/* Large basketball silhouette — top right */}
                <svg
                    class="hero-bball"
                    viewBox="0 0 400 400"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    {/* Outer circle */}
                    <circle
                        cx="200"
                        cy="200"
                        r="195"
                        stroke="#FF6B35"
                        stroke-width="2.5"></circle>
                    {/* Horizontal seam */}
                    <path
                        d="M5 200 Q100 160 200 200 Q300 240 395 200"
                        stroke="#FF6B35"
                        stroke-width="2"
                        fill="none"></path>
                    <path
                        d="M5 200 Q100 240 200 200 Q300 160 395 200"
                        stroke="#FF6B35"
                        stroke-width="2"
                        fill="none"></path>
                    {/* Vertical seam */}
                    <path
                        d="M200 5 Q160 100 200 200 Q240 300 200 395"
                        stroke="#FF6B35"
                        stroke-width="2"
                        fill="none"></path>
                    <path
                        d="M200 5 Q240 100 200 200 Q160 300 200 395"
                        stroke="#FF6B35"
                        stroke-width="2"
                        fill="none"></path>
                </svg>

                {/* Court arc — bottom left, three-point style */}
                <svg
                    class="hero-court-arc"
                    viewBox="0 0 500 300"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <path
                        d="M0 280 Q250 -60 500 280"
                        stroke="#FF6B35"
                        stroke-width="1.5"
                        fill="none"
                        stroke-dasharray="8 6"></path>
                    {/* Lane lines */}
                    <line
                        x1="150"
                        y1="280"
                        x2="150"
                        y2="160"
                        stroke="#FF6B35"
                        stroke-width="1"
                        stroke-dasharray="6 8"></line>
                    <line
                        x1="350"
                        y1="280"
                        x2="350"
                        y2="160"
                        stroke="#FF6B35"
                        stroke-width="1"
                        stroke-dasharray="6 8"></line>
                    {/* Free throw circle */}
                    <ellipse
                        cx="250"
                        cy="160"
                        rx="100"
                        ry="40"
                        stroke="#FF6B35"
                        stroke-width="1.2"
                        fill="none"></ellipse>
                </svg>

                {/* Fadeaway motion trail arc — top left */}
                <svg
                    class="hero-fadeaway-trail"
                    viewBox="0 0 320 220"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <path
                        d="M20 200 Q90 50 270 30"
                        stroke="#FF6B35"
                        stroke-width="2"
                        fill="none"
                        stroke-dasharray="4 5"
                        stroke-linecap="round"></path>
                    {/* Ball at peak of arc — bigger */}
                    <circle
                        cx="270"
                        cy="30"
                        r="28"
                        stroke="#FF6B35"
                        stroke-width="1.5"
                        fill="none"></circle>
                    {/* Horizontal seams */}
                    <path
                        d="M242 30 Q256 18 270 30 Q284 42 298 30"
                        stroke="#FF6B35"
                        stroke-width="1"
                        fill="none"></path>
                    <path
                        d="M242 30 Q256 42 270 30 Q284 18 298 30"
                        stroke="#FF6B35"
                        stroke-width="1"
                        fill="none"></path>
                    {/* Vertical seam */}
                    <path
                        d="M270 2 Q258 16 270 30 Q282 44 270 58"
                        stroke="#FF6B35"
                        stroke-width="1"
                        fill="none"></path>
                    <path
                        d="M270 2 Q282 16 270 30 Q258 44 270 58"
                        stroke="#FF6B35"
                        stroke-width="1"
                        fill="none"></path>
                </svg>

                {/* Subtle dot grid */}
                <div class="hero-dots"></div>
            </div>

            <div class="container-max w-full relative z-10">
                <div
                    class="text-center max-w-3xl mx-auto animate-fade-in pt-16 md:pt-20"
                >
                    {/* Logo — hidden on mobile, shown on desktop */}
                    <div class="hidden md:flex justify-center mb-8">
                        <Image
                            src={logoImage}
                            alt="Fadeaway Creatives"
                            class="h-24 md:h-32 w-auto"
                        />
                    </div>

                    {/* Badge */}
                    <Badge variant="primary">
                        <span>✨</span>
                        <span>Get found. Get clients. Grow online.</span>
                        <span>✨</span>
                    </Badge>

                    {/* H1 */}
                    <h1
                        class="text-5xl md:text-6xl font-outfit font-bold text-neutral-50 mt-6 mb-6 leading-none text-balance"
                    >
                        Dominate Search Results in Your Market
                    </h1>

                    {/* Subtitle */}
                    <p
                        class="text-lg md:text-xl text-neutral-300 mb-6 text-balance leading-relaxed"
                    >
                        SEO-first websites built for performance.<br />
                        Get found online. Attract better leads. Grow with SEO.
                    </p>

                    {/* CTAs */}
                    <div
                        class="flex flex-col sm:flex-row items-center justify-center gap-3 md:gap-4 mb-12"
                    >
                        <a
                            href="https://calendar.app.google/muWWvjBAQdLVuBtM9"
                            target="_blank"
                            rel="noopener"
                        >
                            <Button
                                variant="secondary"
                                size="md"
                                className="min-w-[180px] md:min-w-[200px]"
                                >Book a Growth Call</Button
                            >
                        </a>
                        <a href="#playbooks">
                            <Button
                                variant="secondary"
                                size="md"
                                className="min-w-[180px] md:min-w-[200px]"
                                >View Our Playbooks</Button
                            >
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <style>
            /* ── Hero background layer ── */
            .hero-bg-layer {
                position: absolute;
                inset: 0;
                z-index: 0;
                overflow: hidden;
                pointer-events: none;
            }

            /* Glow orbs */
            .hero-glow {
                position: absolute;
                border-radius: 50%;
                filter: blur(90px);
                pointer-events: none;
            }
            .hero-glow--orange {
                width: 560px;
                height: 420px;
                background: radial-gradient(
                    circle,
                    rgba(255, 107, 53, 0.18) 0%,
                    transparent 70%
                );
                top: 40%;
                left: 50%;
                transform: translate(-50%, -50%);
                animation: glowDrift 14s ease-in-out infinite;
            }
            .hero-glow--teal {
                width: 440px;
                height: 440px;
                background: radial-gradient(
                    circle,
                    rgba(0, 191, 165, 0.1) 0%,
                    transparent 70%
                );
                top: 35%;
                left: 75%;
                transform: translate(-50%, -50%);
                animation: glowDrift2 18s ease-in-out infinite;
            }

            @keyframes glowDrift {
                0%,
                100% {
                    transform: translate(-50%, -50%) translate(0, 0);
                }
                30% {
                    transform: translate(-50%, -50%) translate(50px, -35px);
                }
                60% {
                    transform: translate(-50%, -50%) translate(-30px, 40px);
                }
            }
            @keyframes glowDrift2 {
                0%,
                100% {
                    transform: translate(-50%, -50%) translate(0, 0);
                }
                40% {
                    transform: translate(-50%, -50%) translate(-60px, 50px);
                }
                70% {
                    transform: translate(-50%, -50%) translate(35px, -45px);
                }
            }

            /* Large basketball — top right, cropped */
            .hero-bball {
                position: absolute;
                top: -80px;
                right: -80px;
                width: 420px;
                height: 420px;
                opacity: 0.07;
                animation: ballSpin 40s linear infinite;
            }
            @keyframes ballSpin {
                from {
                    transform: rotate(0deg);
                }
                to {
                    transform: rotate(360deg);
                }
            }

            /* Court arc — bottom left */
            .hero-court-arc {
                position: absolute;
                bottom: -20px;
                left: -40px;
                width: 480px;
                height: 280px;
                opacity: 0.065;
            }

            /* Fadeaway trail arc — upper left, desktop only */
            .hero-fadeaway-trail {
                display: none;
            }
            @media (min-width: 768px) {
                .hero-fadeaway-trail {
                    display: block;
                    position: absolute;
                    top: 60px;
                    left: 40px;
                    width: 280px;
                    height: 180px;
                    opacity: 0.1;
                    animation: trailPulse 6s ease-in-out infinite;
                }
            }
            @keyframes trailPulse {
                0%,
                100% {
                    opacity: 0.1;
                }
                50% {
                    opacity: 0.18;
                }
            }

            /* Dot grid */
            .hero-dots {
                position: absolute;
                inset: 0;
                background-image: radial-gradient(
                    circle,
                    rgba(255, 107, 53, 0.18) 1px,
                    transparent 1px
                );
                background-size: 32px 32px;
                opacity: 0.25;
                mask-image: radial-gradient(
                    ellipse 80% 80% at 50% 50%,
                    black 20%,
                    transparent 100%
                );
            }
        </style>

        {/* ── 02. CHOOSE YOUR PLAYBOOK ── */}
        <section
            id="playbooks"
            class="section-padding bg-fadeaway-darker border-t border-white/5"
        >
            <div class="container-max">
                <div class="text-center mb-12 animate-fade-in">
                    <Badge variant="primary">
                        <span>Industry Playbooks</span>
                    </Badge>
                    <h2
                        class="text-4xl md:text-5xl font-outfit font-bold mt-4 mb-4"
                    >
                        Built for Your <span class="text-fadeaway-teal"
                            >Industry</span
                        >
                    </h2>
                    <p class="text-lg text-neutral-300 max-w-2xl mx-auto">
                        We don't build generic websites. Every playbook is a
                        battle-tested system engineered around how your clients
                        search and book.
                    </p>
                </div>

                <div
                    class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto"
                >
                    {/* Sports Card */}
                    <a
                        href="/sports"
                        class="group relative block overflow-hidden rounded-3xl border border-white/20 bg-fadeaway-graphite hover:border-fadeaway-orange/50 transition-all duration-500 hover:shadow-[0_0_40px_rgba(249,115,22,0.15)]"
                    >
                        <div
                            class="absolute inset-0 bg-gradient-to-br from-fadeaway-orange/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
                        >
                        </div>
                        <Image
                            src={sportsMockupImg}
                            alt="Sports Academy Website"
                            class="w-full h-64 object-cover object-center opacity-90 group-hover:opacity-100 transition-opacity duration-500"
                        />
                        <div class="p-6 md:p-8">
                            <span
                                class="inline-block text-xs font-bold uppercase tracking-widest text-fadeaway-orange mb-3"
                            >
                                Sports Academy Playbook
                            </span>
                            <h3
                                class="text-2xl md:text-3xl font-outfit font-bold text-neutral-50 mb-3"
                            >
                                Dominate Local Search.<br />Fill Your Roster.
                            </h3>
                            <p
                                class="text-neutral-400 text-sm leading-relaxed mb-6"
                            >
                                For sports academies, club programs, and elite
                                training facilities ready to scale memberships
                                and pack their facility.
                            </p>
                            <div
                                class="flex items-center gap-2 text-fadeaway-orange font-semibold text-sm group-hover:gap-4 transition-all duration-300"
                            >
                                <span>View Sports Playbook</span>
                                <svg
                                    class="w-4 h-4"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 5l7 7-7 7"></path>
                                </svg>
                            </div>
                        </div>
                    </a>

                    {/* Wellness Card */}
                    <a
                        href="/wellness"
                        class="group relative block overflow-hidden rounded-3xl border border-white/20 bg-fadeaway-graphite hover:border-fadeaway-teal/50 transition-all duration-500 hover:shadow-[0_0_40px_rgba(20,184,166,0.15)]"
                    >
                        <div
                            class="absolute inset-0 bg-gradient-to-br from-fadeaway-teal/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
                        >
                        </div>
                        <Image
                            src={wellnessMockupImg}
                            alt="Wellness Studio Website"
                            class="w-full h-64 object-cover object-center opacity-90 group-hover:opacity-100 transition-opacity duration-500"
                        />
                        <div class="p-6 md:p-8">
                            <span
                                class="inline-block text-xs font-bold uppercase tracking-widest text-fadeaway-teal mb-3"
                            >
                                Wellness & Boutique Fitness Playbook
                            </span>
                            <h3
                                class="text-2xl md:text-3xl font-outfit font-bold text-neutral-50 mb-3"
                            >
                                Improve Local Rankings.<br />Fully Book Your
                                Schedule.
                            </h3>
                            <p
                                class="text-neutral-400 text-sm leading-relaxed mb-6"
                            >
                                For boutique fitness studios and wellness
                                clinics ready to scale their practice and fill
                                every appointment slot.
                            </p>
                            <div
                                class="flex items-center gap-2 text-fadeaway-teal font-semibold text-sm group-hover:gap-4 transition-all duration-300"
                            >
                                <span>View Wellness Playbook</span>
                                <svg
                                    class="w-4 h-4"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 5l7 7-7 7"></path>
                                </svg>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </section>

        {/* ── 03. HOW WE HELP ── */}
        <StepsGridSection
            title="How We Help Local Businesses Win Local SEO & AI Search."
            bgClass="bg-fadeaway-graphite"
            cardClass="glass-effect bg-white/5 border-white/20"
            subtitle="Most businesses are completely invisible online. We use a multi-pronged system to make sure you are the #1 recommendation on Google and modern AI search engines."
            steps={[
                {
                    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>',
                    title: "Win the Google Map Pack",
                    copy: "We optimize your Google Business Profile so your facility shows up first on the map when parents search for local camps or club teams.",
                },
                {
                    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z" /></svg>',
                    title: "Target Surrounding Neighborhoods",
                    copy: "Clients don't just search your city; they search their specific suburbs. We build pages dedicated to capturing traffic from your entire local area.",
                },
                {
                    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" /></svg>',
                    title: "Be the AI's Top Recommendation",
                    copy: "Users are starting to ask ChatGPT and Google's AI for recommendations. We structure your data so you are the #1 answer AI bots give locally.",
                },
                {
                    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" /></svg>',
                    title: "Automated 5-Star Reviews",
                    copy: "Google and AI favor businesses with fresh reviews. We set up automated reminders to capture these from customers right after a great experience.",
                },
                {
                    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>',
                    title: "Lightning-Fast Speeds",
                    copy: "We build your site to load in under a second, giving you a perfect performance score and pushing you to the top of search results.",
                },
                {
                    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" /></svg>',
                    title: "Track Real Lead Conversions",
                    copy: 'We don’t care about "website views." We track exactly which searches actually led to a paid customer or a booked appointment.',
                },
            ]}
        />

        {/* ── 04. FINAL CTA ── */}
        <ROISection
            title="Build the Digital Engine Your Brand Deserves."
            description="Stop letting bad tech slow down your growth. Let’s build a frictionless, 24/7 digital engine that captures high-intent leads and scales your business on autopilot."
            ctaText="Request Custom Demo"
            ctaLink="/contact"
            microCopy="Zero pressure. We build it, we show you how it works, you decide if you want it."
        />
    </main>

    <Footer />
</Layout>
