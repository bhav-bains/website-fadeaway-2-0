---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import PillarsSection from "../components/PillarsSection.astro";
import AgitatorSection from "../components/AgitatorSection.astro";
import PackagesSection from "../components/PackagesSection.astro";
import TestimonialSection from "../components/TestimonialSection.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import ProjectShowcase from "../components/ProjectShowcase.astro";
import ROISection from "../components/ROISection.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import highPerformanceWebsiteImg from "../assets/high-performance-website.png"; // Placeholder for OG
import websiteDesignHeroImg from "../assets/website-design-background-image-hero.png";
import fadeawayCreativesImg from "../assets/image-fadeaway-creatives.png";
import fcWebPillar2 from "../assets/FC-web-pillar-2.png";
import fcWebPillar3 from "../assets/FC-web-pillar-3.png";
import sportsSidelineImg from "../assets/sports-sideline.png";

const features = [
    {
        title: "Core Web Vitals Optimization",
        description:
            "We guarantee passing scores on Google’s strict performance metrics for LCP, FID, and CLS.",
    },
    {
        title: "SSL/TLS Encryption Certificate",
        description:
            "Standardized security protocols to protect visitor data and establish trust.",
    },
    {
        title: "Global CDN Propagation",
        description:
            "Content Delivery Network integration to serve your site assets from the server closest to your user.",
    },
    {
        title: "Automatic Cache Invalidation",
        description:
            "Ensuring users always see the latest version of your site without manual refreshing.",
    },
    {
        title: "Responsive Viewport Configuration",
        description:
            "Fluid layouts that adapt pixel-perfectly to mobile, tablet, and desktop breakpoints.",
    },
    {
        title: "Semantic HTML5 Architecture",
        description:
            "Clean code structure that helps search engine crawlers index your content accurately.",
    },
    {
        title: "Image Optimization & WebP Conversion",
        description:
            "Next-gen image formatting to reduce payload size without sacrificing quality.",
    },
    {
        title: "Uptime Monitoring & Alerts",
        description:
            "24/7 automated surveillance to ensure your digital storefront never goes dark.",
    },
    {
        title: "Server-Side Security Patching",
        description:
            "Proactive defense against vulnerabilities and malicious traffic spikes.",
    },
    {
        title: "Schema Markup Implementation",
        description:
            "Structured data integration to help rich snippets appear in search results.",
    },
    {
        title: "Monthly Analytics Reporting",
        description:
            "Transparent data regarding traffic sources, bounce rates, and user acquisition.",
    },
    {
        title: "Content Management Support",
        description:
            "Regular content updates handled by our team so you never touch a line of code.",
    },
];

const pillars = [
    {
        title: "Elite User Experience",
        copy: "First impressions are the difference between a lead and a bounce. We deploy a sub-3-click mobile checkout that syncs directly with your court or facility availability, guiding parents from 'just looking' to 'signed up' while saving you hours of weekly admin work.",
        image: fadeawayCreativesImg,
    },
    {
        title: "SEO for Local Dominance",
        copy: "Most sports sites are buried on page 3. We optimize your Google Business Profile to dominate the local Map Pack. Clean code and hyper-local landing pages ensure you rank #1 when parents search for camps and club teams in your city.",
        image: fcWebPillar2,
    },
    {
        title: "Built for the Season",
        copy: 'Your business evolves, and your site should too. From clear "Athlete Pathways" to complex schedule integrations and automated registration engines, our architecture captures leads and fills your facility to maximum capacity without ever needing a rebuild.',
        image: fcWebPillar3,
    },
];
---

<Layout
    title="High-Performance Websites for Sports & Fitness | Fadeaway Creatives"
    description="Dominate your local market with an SEO-first website built for sports academies, fitness brands, and high-performance teams."
    ogImage={highPerformanceWebsiteImg.src}
>
    <Header />

    <main>
        {/* 01. Hero Section */}
        <Hero
            title="Turn Your Website Into a Roster-Filling Engine"
            subtitle="Stop treating your website like a digital brochure. We build high-converting, mobile-first booking engines strictly for elite sports academies and club programs. Scale your memberships and pack your facility."
            ctaText="Get Your Custom Demo"
            ctaLink="/audit-request"
            cta2Text="View Packages"
            cta2Link="/#pricing"
            badgeText="YOUR 24/7 ENROLLMENT OFFICER"
            backgroundImage={websiteDesignHeroImg}
        />

        {/* 02. The Sideline Reality Check (Agitator) */}
        <AgitatorSection
            title="Parents Are Booking From the Sidelines. Are You Losing Them?"
            body="90% of parents search for training programs on their phones while sitting at their kids' games or practices. If your site has walls of text, doesn't showcase your coaches' pedigree, or takes more than 3 clicks to check out, they are bouncing to a rival club."
            punchline="You aren't just losing clicks.<br />You are losing $2,000+ LTV memberships."
            backgroundImage={sportsSidelineImg}
        />

        {/* 04. The 3 Pillars */}
        <PillarsSection
            title="The Academy Growth Blueprint"
            pillars={pillars}
        />

        {/* 05. Packages / Pricing */}
        <PackagesSection
            eyebrow="PRICING"
            title={`Simple, Transparent <span class="text-fadeaway-teal">Packages</span>`}
            subtitle="No hourly billing. No custom quote games. Just high-performance digital engines designed to pack your facility."
            packages={[
                {
                    name: "Attract",
                    badge: "Most Popular",
                    price: "$499",
                    period: "/month",
                    setup: "$999 one-time website build setup",
                    description:
                        "For sports programs ready to turn mobile traffic into booked athletes.",
                    features: [
                        "Hosting, SSL, backups, uptime monitoring",
                        "High-speed, mobile-first SEO-ready website build",
                        "Direct booking & facility calendar sync",
                        "Google Business Profile (Map Pack) setup",
                        "Live SEO dashboard",
                        "Monthly strategy call",
                        "SEO campaigns (keyword tracking, blog posts, Google Business Profile optimization)",
                    ],
                    tagline:
                        "Attract more customers every single month. Stop losing parents to slow, broken scheduling links.",
                    ctaText: "See the demo",
                    ctaLink: "/audit-request",
                    highlighted: true,
                },
                {
                    name: "Growth",
                    price: "$999",
                    period: "/month",
                    setup: "$999 one-time website build setup",
                    description:
                        "For elite facilities ready to dominate local search and scale rapidly.",
                    features: [
                        "Everything in the Attract package",
                        "Weekly strategy calls",
                        "Advanced lead generation campaigns",
                        "Paid ad management (Google & Meta)",
                        "Hyper-local neighborhood SEO landing pages",
                        "Social media campaign support",
                        "Advanced capacity & direct-attribution analytics",
                        "Automated parent review request system",
                    ],
                    tagline:
                        "Scale registrations and facility capacity on autopilot.",
                    ctaText: "See the demo",
                    ctaLink: "/audit-request",
                },
            ]}
        >
            <div slot="footer" class="mt-8 md:mt-12 text-center max-w-2xl mx-auto glass-effect border-white/5 py-4 px-6 md:py-6 rounded-2xl relative overflow-hidden group hover:border-white/10 transition-colors">
                <div class="absolute inset-0 bg-gradient-to-r from-fadeaway-teal/5 to-fadeaway-orange/5 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
                
                <p class="text-neutral-400 text-sm md:text-base leading-relaxed relative z-10">
                    Need something completely custom? We orchestrate <span class="text-neutral-200 font-medium whitespace-nowrap">bespoke builds</span> and <span class="text-fadeaway-teal font-medium whitespace-nowrap">automations</span> to bring your ideas to reality. <a href="/audit-request" class="text-fadeaway-orange hover:text-white transition-colors underline decoration-fadeaway-orange/30 hover:decoration-fadeaway-orange underline-offset-4 ml-1 whitespace-nowrap">Let's connect.</a>
                </p>
            </div>
        </PackagesSection>

        <TestimonialSection 
            testimonials={[
                {
                    headline: "Summer camps sold out in 3 weeks.",
                    quote: "We used to rely entirely on word of mouth. Bhav and the team completely overhauled our local SEO and Google Business Profile. Now, when parents search for 'kids basketball camps' in our city, we show up first. We hit maximum facility capacity faster than ever.",
                    author: "[Name]",
                    role: "Owner at [Facility Name]",
                    stars: 5
                },
                {
                    headline: "Leads doubled in half the time.",
                    quote: "The team at Fadeaway built a platform that sells our vision 24/7. Our booking process is streamlined, and parents literally compliment us on how easy the checkout is from their phones.",
                    author: "[Name]",
                    role: "Director at [Facility Name]",
                    stars: 5
                },
                {
                    headline: "We spend zero time doing admin.",
                    quote: "Our site used to be a brochure. Now it's a full registration engine. The automated scheduling means we don't have to hire a receptionist, saving us thousands a month.",
                    author: "[Name]",
                    role: "GM at [Facility Name]",
                    stars: 5
                }
            ]}
        />

        {
            /* 05. The Solution: Why Astro? — HIDDEN
        <PillarsSection
            title="Modern Tech for an Active World"
            pillars={[
                {
                    title: "Lightning Fast Mobile Loads",
                    copy: "Aastro components serve zero hydration JS by default. Your site loads in milliseconds, capturing parents' attention before they look back at the field.",
                    image: fcWebPillar2,
                },
                {
                    title: "SEO-First Architecture",
                    copy: "Clean HTML structure and automated sitemaps ensure you're at the top of Google when a parent searches for local clubs.",
                    image: fcWebPillar3,
                },
                {
                    title: "Roster Management Ready",
                    copy: "Seamless integration with registration platforms or custom tournament filters. built to grow with your program.",
                    image: fadeawayCreativesImg,
                }
            ]}
        />
        */
        }

        {
            /* 05. Features Grid — HIDDEN
        <FeatureGrid
            title="Enterprise-Grade Tech Included Standard"
            subtitle="Why pay thousands for a custom build? We include all of this in our standard maintenance plans."
            features={features}
        />
        */
        }

        {
            /* 06. Social Proof / Demo Showcase — HIDDEN
        <ProjectShowcase
            projects={[
                { title: "MetroStars Academy Performance Build" },
                { title: "Elite Performance Training Demo" },
            ]}
        />
        */
        }

        {
            /* 07. Closing / ROI Section — HIDDEN
        <ROISection />
        */
        }
    </main>
    <Footer />
</Layout>
