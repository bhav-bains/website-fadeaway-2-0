---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Button from "../components/Button.astro";
import Badge from "../components/Badge.astro";
---

<Layout title="Message Sent | Fadeaway Creatives">
    <Header />

    <main class="pt-24 min-h-screen">
        <section class="section-padding">
            <div class="container-max max-w-4xl mx-auto text-center">
                <div class="mb-12 animate-fade-in">
                    <Badge variant="primary">
                        <span>Success</span>
                    </Badge>
                    <h1 class="text-4xl md:text-5xl font-outfit font-bold mt-4 mb-4">
                        We've Received Your Details!
                    </h1>
                    <p class="text-xl text-neutral-300 max-w-2xl mx-auto mb-10">
                        Thank you for reaching out! We have successfully received your details. A member of our team will review your message and get back to you within 24 hours.
                    </p>
                    <div class="flex justify-center">
                        <a href="/">
                            <Button variant="primary" size="md">Back to Homepage</Button>
                        </a>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Layout>
