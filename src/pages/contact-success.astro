---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Button from "../components/Button.astro";
import Badge from "../components/Badge.astro";
---

<Layout title="Message Sent | Fadeaway Creatives">
    <Header />

    <main class="pt-24 min-h-screen">
        <section class="section-padding">
            <div class="container-max max-w-4xl mx-auto text-center">
                <div class="mb-12 animate-fade-in">
                    <Badge variant="primary">
                        <span>Success</span>
                    </Badge>
                    <h1 class="text-4xl md:text-5xl font-outfit font-bold mt-4 mb-4">
                        We've Received Your Details!
                    </h1>
                    <p class="text-xl text-neutral-300 max-w-2xl mx-auto">
                        One last step to confirm your custom demo — please book a time on the calendar below for your 15-minute walkthrough.
                    </p>
                </div>

                <div
                    class="glass-effect p-4 md:p-6 rounded-3xl animate-slide-up border border-white/10 shadow-2xl bg-[#1a1a1c]/30 backdrop-blur-xl overflow-hidden"
                >
                    <!-- Google Calendar Appointment Scheduling begin -->
                    <iframe 
                        src="https://calendar.google.com/calendar/appointments/schedules/AcZssZ1kpzbQL7FmgB-XKiRGJbBtXxfpJQE7ESZrGNcxMNQbfNJmTi6FQb0a737-48v-8tmmC0X0ik4e?gv=true" 
                        style="border: 0" 
                        width="100%" 
                        height="700" 
                        frameborder="0"
                        class="rounded-2xl bg-white"
                    ></iframe>
                    <!-- end Google Calendar Appointment Scheduling -->
                </div>
                
                <p class="mt-8 text-neutral-400">
                    Can't find a time? <a href="/contact" class="text-fadeaway-orange hover:underline">Go back</a> or message us on WhatsApp.
                </p>
            </div>
        </section>
    </main>

    <Footer />
</Layout>
