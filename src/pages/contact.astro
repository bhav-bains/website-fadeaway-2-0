---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Button from "../components/Button.astro";
import Badge from "../components/Badge.astro";
---

<Layout
    title="Contact Us | Fadeaway Creatives"
    description="Ready to scale your sports or wellness brand? Send us a message and we'll build the digital engine your academy deserves."
>
    <Header />

    <main class="pt-24 min-h-screen">
        <section class="section-padding">
            <div class="container-max max-w-6xl mx-auto">
                <div class="text-center mb-16 animate-fade-in">
                    <Badge variant="primary">
                        <span>Contact</span>
                    </Badge>
                    <h1
                        class="text-4xl md:text-5xl lg:text-6xl font-outfit font-bold mt-4 mb-4"
                    >
                        Build the Digital Engine Your <span
                            class="text-fadeaway-teal">Brand Deserves</span
                        >
                    </h1>
                    <p class="text-lg text-neutral-300 max-w-2xl mx-auto">
                        Fill out the details below. We will take your current
                        brand assets and engineer a high-performance growth
                        machine demo. We'll show you the exact results on a
                        15-minute walkthrough.
                    </p>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-[1.2fr,0.8fr] gap-12 items-start">
                    {/* Left Column: Form */}
                    <div
                        class="glass-effect p-6 md:p-10 rounded-3xl border border-white/10 animate-slide-up"
                    >
                        <form
                            name="website-contact-form"
                            method="POST"
                            action="/contact-success"
                            data-netlify="true"
                            data-netlify-honeypot="bot-field"
                            class="space-y-6"
                        >
                            {/* Netlify Form Name for Static Hosting */}
                            <input type="hidden" name="form-name" value="website-contact-form" />

                            {/* Spam Protection (Honeypot) */}
                            <div class="hidden">
                                <label>Don't fill this out if you're human: <input name="bot-field" /></label>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label
                                        for="name"
                                        class="block text-sm font-medium text-neutral-300 mb-2"
                                    >
                                        Your Name
                                    </label>
                                    <input
                                        type="text"
                                        name="name"
                                        id="name"
                                        required
                                        placeholder="John Doe"
                                        class="input-primary w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:border-fadeaway-teal/50 outline-none transition-colors"
                                    />
                                </div>

                                <div>
                                    <label
                                        for="email"
                                        class="block text-sm font-medium text-neutral-300 mb-2"
                                    >
                                        Email Address
                                    </label>
                                    <input
                                        type="email"
                                        name="email"
                                        id="email"
                                        required
                                        placeholder="john@example.com"
                                        class="input-primary w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:border-fadeaway-teal/50 outline-none transition-colors"
                                    />
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label
                                        for="phone"
                                        class="block text-sm font-medium text-neutral-300 mb-2"
                                    >
                                        Contact Number
                                    </label>
                                    <input
                                        type="tel"
                                        name="phone"
                                        id="phone"
                                        placeholder="+1 (555) 000-0000"
                                        class="input-primary w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:border-fadeaway-teal/50 outline-none transition-colors"
                                    />
                                </div>

                                <div>
                                    <label
                                        for="website"
                                        class="block text-sm font-medium text-neutral-300 mb-2"
                                    >
                                        Website URL / Company Name
                                    </label>
                                    <input
                                        type="text"
                                        name="website"
                                        id="website"
                                        required
                                        placeholder="https://yourbusiness.com"
                                        class="input-primary w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:border-fadeaway-teal/50 outline-none transition-colors"
                                    />
                                </div>
                            </div>

                            <div>
                                <label
                                    for="message"
                                    class="block text-sm font-medium text-neutral-300 mb-2"
                                >
                                    Your Message
                                </label>
                                <textarea
                                    name="message"
                                    id="message"
                                    required
                                    placeholder="Tell us about your biggest growth bottlenecks or goals..."
                                    class="input-primary w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:border-fadeaway-teal/50 outline-none transition-colors min-h-[150px] resize-none"
                                ></textarea>
                            </div>

                            <div class="pt-2">
                                <Button
                                    variant="secondary"
                                    size="lg"
                                    className="w-full"
                                    type="submit"
                                >
                                    Send Message
                                </Button>
                                <p
                                    class="text-xs text-center text-neutral-500 mt-4"
                                >
                                    We typically respond in less than 24 hours.
                                </p>
                            </div>
                        </form>
                    </div>

                    {/* Right Column: Contact Info */}
                    <div class="space-y-6 lg:pt-4 animate-slide-up" style="animation-delay: 0.1s;">
                        <div>
                            <h3 class="text-2xl font-outfit font-bold text-neutral-50 mb-2">Other Ways to Connect</h3>
                            <p class="text-neutral-400 mb-8">Reach us directly on social or via message.</p>
                        </div>

                        <div class="flex flex-col gap-4">
                            {/* WhatsApp */}
                            <a 
                                href="https://wa.me/17056500328" 
                                target="_blank" 
                                class="group flex items-center gap-4 p-4 glass-effect border border-white/10 rounded-3xl hover:border-fadeaway-orange/40 transition-all duration-300"
                            >
                                <div class="text-white/40 group-hover:text-fadeaway-orange transition-colors">
                                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                                </div>
                                <div>
                                    <span class="block text-neutral-50 font-bold text-lg">WhatsApp</span>
                                    <span class="text-sm text-neutral-400">Message on WhatsApp</span>
                                </div>
                            </a>

                            {/* Email */}
                            <a 
                                href="mailto:hello@fadeawaycreatives.com" 
                                class="group flex items-center gap-4 p-4 glass-effect border border-white/10 rounded-3xl hover:border-fadeaway-orange/40 transition-all duration-300"
                            >
                                <div class="text-white/40 group-hover:text-fadeaway-orange transition-colors">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                                </div>
                                <div>
                                    <span class="block text-neutral-50 font-bold text-lg">Email</span>
                                    <span class="text-sm text-neutral-400">Contact via Email</span>
                                </div>
                            </a>

                            {/* Instagram */}
                            <a 
                                href="https://instagram.com" 
                                target="_blank" 
                                class="group flex items-center gap-4 p-4 glass-effect border border-white/10 rounded-3xl hover:border-fadeaway-orange/40 transition-all duration-300"
                            >
                                <div class="text-white/40 group-hover:text-fadeaway-orange transition-colors">
                                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                                </div>
                                <div>
                                    <span class="block text-neutral-50 font-bold text-lg">Instagram</span>
                                    <span class="text-sm text-neutral-400">DM on Instagram</span>
                                </div>
                            </a>

                            {/* Facebook */}
                            <a 
                                href="https://facebook.com" 
                                target="_blank" 
                                class="group flex items-center gap-4 p-4 glass-effect border border-white/10 rounded-3xl hover:border-fadeaway-orange/40 transition-all duration-300"
                            >
                                <div class="text-white/40 group-hover:text-fadeaway-orange transition-colors">
                                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22.675 0h-21.35c-.732 0-1.325.593-1.325 1.325v21.351c0 .731.593 1.324 1.325 1.324h11.495v-9.294h-3.128v-3.622h3.128v-2.671c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.312h3.587l-.467 3.622h-3.12v9.293h6.116c.73 0 1.323-.593 1.323-1.325v-21.35c0-.732-.593-1.325-1.325-1.325z"/></svg>
                                </div>
                                <div>
                                    <span class="block text-neutral-50 font-bold text-lg">Facebook</span>
                                    <span class="text-sm text-neutral-400">DM on Facebook</span>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Layout>
