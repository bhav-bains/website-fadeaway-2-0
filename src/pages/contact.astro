---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Button from "../components/Button.astro";
import Badge from "../components/Badge.astro";
---

<Layout title="Contact Us | Fadeaway Creatives" description="Ready to scale your sports or wellness brand? Send us a message and we'll build the digital engine your academy deserves.">
    <Header />

    <main class="pt-24 min-h-screen">
        <section class="section-padding">
            <div class="container-max max-w-2xl mx-auto">
                <div class="text-center mb-10 animate-fade-in">
                    <Badge variant="primary">
                        <span>Contact</span>
                    </Badge>
                    <h1
                        class="text-4xl md:text-5xl font-outfit font-bold mt-4 mb-4"
                    >
                        Build the Digital Engine Your <span class="text-fadeaway-teal"
                            >Brand Deserves</span
                        >
                    </h1>
                    <p class="text-lg text-neutral-300">
                        Ready to scale? Send us a message and we'll get back to you within 24 hours.
                    </p>
                </div>

                <div
                    class="glass-effect p-6 md:p-8 rounded-2xl animate-slide-up"
                >
                    <form
                        name="contact"
                        method="POST"
                        action="/contact-success"
                        data-netlify="true"
                        class="space-y-4"
                    >
                        <div class="space-y-4">
                            <div>
                                <label
                                    for="name"
                                    class="block text-sm font-medium text-neutral-300 mb-1"
                                >
                                    Your Name
                                </label>
                                <input
                                    type="text"
                                    name="name"
                                    id="name"
                                    required
                                    placeholder="John Doe"
                                    class="input-primary w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:border-fadeaway-teal/50 outline-none transition-colors"
                                />
                            </div>

                            <div>
                                <label
                                    for="email"
                                    class="block text-sm font-medium text-neutral-300 mb-1"
                                >
                                    Email Address
                                </label>
                                <input
                                    type="email"
                                    name="email"
                                    id="email"
                                    required
                                    placeholder="john@example.com"
                                    class="input-primary w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:border-fadeaway-teal/50 outline-none transition-colors"
                                />
                            </div>

                            <div>
                                <label
                                    for="website"
                                    class="block text-sm font-medium text-neutral-300 mb-1"
                                >
                                    Website URL / Company Name
                                </label>
                                <input
                                    type="text"
                                    name="website"
                                    id="website"
                                    required
                                    placeholder="https://yourbusiness.com"
                                    class="input-primary w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:border-fadeaway-teal/50 outline-none transition-colors"
                                />
                            </div>

                            <div>
                                <label
                                    for="message"
                                    class="block text-sm font-medium text-neutral-300 mb-1"
                                >
                                    Your Message
                                </label>
                                <textarea
                                    name="message"
                                    id="message"
                                    required
                                    placeholder="Tell us about your project, goals, or any questions you have..."
                                    class="input-primary w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:border-fadeaway-teal/50 outline-none transition-colors min-h-[150px] resize-none"
                                ></textarea>
                            </div>

                            <div class="pt-2">
                                <Button
                                    variant="primary"
                                    size="lg"
                                    className="w-full"
                                    type="submit"
                                >
                                    Send Message
                                </Button>
                                <p
                                    class="text-xs text-center text-neutral-500 mt-3"
                                >
                                    We typically respond in less than 24 hours.
                                </p>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Layout>
