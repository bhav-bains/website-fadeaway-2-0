---
import { Image } from "astro:assets";
import Button from "./Button.astro";
import Badge from "./Badge.astro";

interface Props {
    title: string;
    subtitle: string;
    ctaText: string;
    ctaLink: string;
    cta2Text?: string;
    cta2Link?: string;
    badgeText?: string;
    backgroundImage?: ImageMetadata;
}

const {
    title,
    subtitle,
    ctaText,
    ctaLink,
    cta2Text,
    cta2Link,
    badgeText = "Service",
    backgroundImage,
} = Astro.props;
---

<section
    class="relative pt-32 pb-20 md:pt-48 md:pb-32 flex items-center justify-center section-padding overflow-hidden"
>
    {/* Background Image */}
    {
        backgroundImage && (
            <div class="absolute inset-0 -z-20">
                <Image
                    src={backgroundImage}
                    alt=""
                    class="w-full h-full object-cover"
                    quality="high"
                />
                <div class="absolute inset-0 bg-neutral-950/20" />
            </div>
        )
    }

    {/* Geometric Background */}
    <div
        class="absolute inset-0 -z-10 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]"
    >
    </div>

    {/* Subtle Glow */}
    <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-fadeaway-teal/5 rounded-full blur-[120px] pointer-events-none"
    >
    </div>

    <div
        class="container-max relative z-10 text-center flex flex-col items-center justify-center h-full"
    >
        <div class="animate-fade-in flex flex-col items-center md:mt-[48px]">
            <div class="mb-2">
                <Badge variant="primary">
                    <span>{badgeText}</span>
                </Badge>
            </div>

            <h1
                class="text-4xl sm:text-5xl md:text-7xl font-outfit font-bold text-neutral-50 mb-4 md:mb-6 leading-tight text-balance max-w-5xl mx-auto"
            >
                {title}
            </h1>

            <p
                class="text-base md:text-xl text-neutral-300 mb-6 md:mb-8 text-balance max-w-3xl mx-auto leading-relaxed opacity-90"
            >
                {subtitle}
            </p>

            <div class="flex flex-col sm:flex-row justify-center gap-3 md:gap-4">
                <a href={ctaLink}>
                    <Button
                        variant="secondary"
                        size="md"
                        className="md:size-lg min-w-[180px] md:min-w-[200px]"
                    >
                        {ctaText}
                    </Button>
                </a>
                {cta2Text && cta2Link && (
                    <a href={cta2Link}>
                        <Button
                            variant="secondary"
                            size="md"
                            className="md:size-lg min-w-[180px] md:min-w-[200px]"
                        >
                            {cta2Text}
                        </Button>
                    </a>
                )}
            </div>
        </div>
    </div>
</section>
