---
import { Image } from "astro:assets";
import fadeawayLogo from "../assets/fadeaway-logo-2.png";

const { pathname } = Astro.url;
const normalizedPath = pathname.replace(/\/$/, "");

const navigation = [
  {
    label: 'Services',
    type: 'dropdown',
    items: [
      { label: 'Audit & Growth Strategy', href: '#' },
      { label: 'Website Redesign', href: '#' },
      { label: 'Site Migrations', href: '#' },
      { label: 'Idea to MVP', href: '#' }
    ]
  },
  {
    label: 'Solutions',
    type: 'dropdown',
    items: [
      { label: 'Sports Academies', href: '/sports' },
      { label: 'Boutique Fitness & Wellness', href: '/wellness' },
      { label: 'Startups & SaaS', href: '#' },
      { label: 'E-commerce Stores', href: '#' }
    ]
  }
];

const socialLinks = [
  {
    name: 'Instagram',
    href: 'https://instagram.com/fadeawaycreatives',
    icon: `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" /></svg>`
  },
  {
    name: 'Facebook',
    href: 'https://facebook.com/fadeawaycreatives',
    icon: `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M22.675 0h-21.35c-.732 0-1.325.593-1.325 1.325v21.351c0 .731.593 1.324 1.325 1.324h11.495v-9.294h-3.128v-3.622h3.128v-2.671c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.312h3.587l-.467 3.622h-3.12v9.293h6.116c.73 0 1.323-.593 1.323-1.325v-21.35c0-.732-.593-1.325-1.325-1.325z" /></svg>`
  },
  {
    name: 'Email',
    href: 'mailto:hello@fadeawaycreatives.com',
    icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`
  }
];
---

<header id="main-header" class="z-[100] transition-all duration-300 absolute top-0 left-0 right-0 py-3 px-4 md:px-6">
  <div class="container-max flex items-center justify-between md:hidden">
    <a href="/" class="z-50">
      <Image src={fadeawayLogo} alt="Fadeaway Creatives" class="h-8 w-auto" />
    </a>
    
    <!-- Mobile Menu Toggle Button -->
    <button
      id="menu-toggle"
      aria-label="Toggle Menu"
      class="hover:bg-white/5 rounded-lg transition-all duration-300 backdrop-blur-md bg-black/30 border border-white/10 p-1.5 text-white"
    >
      <svg id="menu-icon" class="w-5 h-5 fill-none stroke-current" viewBox="0 0 24 24">
        <path
          class="menu-path-open"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"
        />
        <path
          class="menu-path-close hidden"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"
        />
      </svg>
    </button>
  </div>

  <!-- Desktop Navigation -->
  <div class="hidden md:block container-max max-w-5xl mx-auto">
    <div id="desktop-nav-container" class="backdrop-blur-md bg-black/30 border border-white/10 shadow-lg transition-all duration-300 flex items-center justify-between px-6 rounded-xl py-1.5">
      <a href="/" class="flex-shrink-0">
        <Image src={fadeawayLogo} alt="Fadeaway Creatives" class="h-10 w-auto" />
      </a>

      <nav class="flex items-center justify-center gap-6">
        <div class="flex flex-row items-center gap-2">
          {navigation.map((item) => {
            if (item.type === 'dropdown') {
              return (
                <div class="relative group py-2">
                  <button class="transition-all duration-300 font-medium text-sm px-3 py-1 text-neutral-400 hover:text-white flex items-center gap-1">
                    <span>{item.label}</span>
                    <svg class="w-3.5 h-3.5 text-neutral-500 group-hover:text-white transition-transform duration-300 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                    </svg>
                  </button>
                  {/* Dropdown Menu Panel */}
                  <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 scale-95 pointer-events-none group-hover:opacity-100 group-hover:scale-100 group-hover:pointer-events-auto transition-all duration-200 z-[110] min-w-[240px]">
                    <div class="backdrop-blur-lg bg-[#111112]/95 border border-white/10 rounded-xl shadow-2xl p-2 flex flex-col gap-1">
                      {item.items.map((subItem) => (
                        <a
                          href={subItem.href}
                          class="px-4 py-2.5 rounded-lg text-sm text-neutral-400 hover:text-white hover:bg-white/5 transition-all duration-200 block"
                        >
                          {subItem.label}
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              );
            } else {
              const isActive = normalizedPath === item.href;
              return (
                <a
                  href={item.href}
                  class={`transition-all duration-300 font-medium text-sm px-3 py-1 relative ${
                    isActive 
                    ? "text-white after:absolute after:bottom-0 after:left-3 after:right-3 after:h-0.5 after:bg-fadeaway-orange" 
                    : "text-neutral-400 hover:text-white"
                  }`}
                >
                  {item.label}
                </a>
              );
            }
          })}
        </div>
      </nav>

      <a
        href="/contact"
        class="bg-fadeaway-orange/10 border border-fadeaway-orange/50 text-fadeaway-orange hover:bg-fadeaway-orange hover:text-black transition-all duration-300 font-bold text-xs px-4 py-1.5 rounded-lg uppercase tracking-wider shadow-[0_0_10px_rgba(249,115,22,0.15)]"
      >
        Contact
      </a>
    </div>
  </div>

  <!-- Mobile Navigation Menu -->
  <nav id="mobile-menu" class="hidden md:hidden absolute top-full left-0 right-0 h-[calc(100vh-60px)] backdrop-blur-sm bg-black/40 transition-all duration-300">
    <div class="m-4 rounded-3xl backdrop-blur-2xl bg-[#1a1a1c]/90 border border-white/10 shadow-[0_0_40px_rgba(0,0,0,0.5)] flex flex-col items-stretch gap-3.5 p-6 py-8 w-full max-w-sm mx-auto mt-4 overflow-y-auto max-h-[80vh]">
      {navigation.map((item) => {
        if (item.type === 'dropdown') {
          return (
            <div class="mobile-dropdown-container flex flex-col w-full">
              <button
                class="mobile-dropdown-toggle transition-all duration-300 flex items-center justify-between font-outfit font-medium text-[16px] px-5 py-3.5 rounded-2xl w-full bg-white/5 border border-white/10 text-neutral-300 hover:bg-white/10 hover:text-white"
              >
                <span>{item.label}</span>
                <svg class="w-4 h-4 text-neutral-500 transition-transform duration-300 mobile-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                </svg>
              </button>
              <div class="mobile-dropdown-menu hidden flex-col gap-1.5 pl-4 pr-2 py-2 mt-2 border-l border-white/10">
                {item.items.map((subItem) => (
                  <a
                    href={subItem.href}
                    class="px-4 py-2.5 rounded-xl text-[14px] text-neutral-400 hover:text-white hover:bg-white/5 transition-all duration-200 block"
                  >
                    {subItem.label}
                  </a>
                ))}
              </div>
            </div>
          );
        } else {
          const isActive = normalizedPath === item.href;
          return (
            <a
              href={item.href}
              class={`mobile-nav-link transition-all duration-300 flex items-center justify-between font-outfit font-medium text-[16px] px-5 py-3.5 rounded-2xl w-full ${
                isActive 
                ? "bg-fadeaway-orange/20 border border-fadeaway-orange/50 text-white shadow-inner" 
                : "bg-white/5 border border-white/10 text-neutral-300 hover:bg-white/10 hover:text-white"
              }`}
            >
              <span>{item.label}</span>
              {item.label !== 'Fadeaway Labs' && (
                <svg class={`w-5 h-5 ${isActive ? 'text-fadeaway-orange shadow-sm' : 'text-neutral-500'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              )}
            </a>
          );
        }
      })}
      
      <div class="h-px bg-white/10 my-1 w-full"></div>

      <a
        href="/contact"
        class="mobile-nav-link bg-fadeaway-orange hover:bg-orange-500 text-black transition-all duration-300 font-bold text-[15px] px-6 py-4 rounded-2xl uppercase tracking-wider w-full text-center shadow-[0_0_20px_rgba(249,115,22,0.3)] mt-1"
      >
        Contact
      </a>

      {/* Social Links Row */}
      <div class="flex items-center justify-center gap-3 mt-2.5">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith('mailto:') ? '_self' : '_blank'}
            rel="noopener"
            class="w-8 h-8 flex items-center justify-center bg-white/5 border border-white/10 hover:border-fadeaway-orange/40 text-neutral-400 hover:text-white rounded-lg transition-all duration-300"
            aria-label={link.name}
          >
            <span class="[&>svg]:w-4 [&>svg]:h-4" set:html={link.icon} />
          </a>
        ))}
      </div>
    </div>
  </nav>
</header>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuPathOpen = document.querySelector('.menu-path-open');
  const menuPathClose = document.querySelector('.menu-path-close');
  const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

  // Handle Mobile Menu Toggle
  function toggleMenu() {
    const isExpanded = !mobileMenu?.classList.contains('hidden');
    if (mobileMenu && menuPathOpen && menuPathClose) {
      if (isExpanded) {
        mobileMenu.classList.add('hidden');
        mobileMenu.classList.remove('flex', 'flex-col');
        menuPathOpen.classList.remove('hidden');
        menuPathClose.classList.add('hidden');
      } else {
        mobileMenu.classList.remove('hidden');
        mobileMenu.classList.add('flex', 'flex-col');
        menuPathOpen.classList.add('hidden');
        menuPathClose.classList.remove('hidden');
      }
    }
  }

  // Close menu on link click
  mobileNavLinks.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      mobileMenu?.classList.remove('flex', 'flex-col');
      menuPathOpen?.classList.remove('hidden');
      menuPathClose?.classList.add('hidden');
    });
  });

  menuToggle?.addEventListener('click', toggleMenu);

  // Handle Mobile Dropdown Toggles
  const mobileDropdowns = document.querySelectorAll('.mobile-dropdown-container');
  mobileDropdowns.forEach(container => {
    const toggleBtn = container.querySelector('.mobile-dropdown-toggle');
    const menu = container.querySelector('.mobile-dropdown-menu');
    const chevron = container.querySelector('.mobile-chevron');
    
    toggleBtn?.addEventListener('click', () => {
      if (menu?.classList.contains('hidden')) {
        menu.classList.remove('hidden');
        menu.classList.add('flex');
        chevron?.classList.add('rotate-180');
      } else {
        menu?.classList.add('hidden');
        menu?.classList.remove('flex');
        chevron?.classList.remove('rotate-180');
      }
    });
  });
</script>
