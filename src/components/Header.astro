---
const navLinks = [
  { label: 'Sports Playbook', href: '/sports' },
  { label: 'Wellness Playbook', href: '/wellness' },
];

const socialLinks = [
  {
    name: 'Twitter',
    href: '#',
    icon: `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2s9 5 20 5a9.5 9.5 0 00-9-5.5c4.75 2.25 7-7 7-7" /></svg>`
  },
  {
    name: 'LinkedIn',
    href: '#',
    icon: `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z" /><circle cx="4" cy="4" r="2" /></svg>`
  },
  {
    name: 'Instagram',
    href: '#',
    icon: `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><rect width="20" height="20" x="2" y="2" rx="5" ry="5" /><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37zm1.5-4.87h.01" /></svg>`
  },
];
---

<header id="main-header" class="z-[100] transition-all duration-300 fixed top-0 left-0 right-0 py-4 px-4 md:px-6">
  <!-- Mobile Menu Button -->
  <button
    id="menu-toggle"
    aria-label="Toggle Menu"
    class="md:hidden hover:bg-white/5 rounded-lg transition-all duration-300 absolute right-2 top-2 z-50 backdrop-blur-md bg-black/30 border border-white/10 p-1.5 text-white"
  >
    <svg id="menu-icon" class="w-5 h-5 fill-none stroke-current" viewBox="0 0 24 24">
      <path
        class="menu-path-open"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M4 6h16M4 12h16M4 18h16"
      />
      <path
        class="menu-path-close hidden"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M6 18L18 6M6 6l12 12"
      />
    </svg>
  </button>

  <!-- Desktop Navigation -->
  <div class="hidden md:block container-max max-w-4xl mx-auto">
    <div id="desktop-nav-container" class="backdrop-blur-md bg-black/30 border border-white/10 shadow-lg transition-all duration-300 flex items-center justify-center px-4 md:px-6 rounded-2xl py-2">
      <nav class="flex items-center justify-center gap-3">
        <div class="flex flex-row items-center gap-3 rounded-lg p-2 px-4 py-1 transition-all duration-300">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="text-neutral-50 hover:text-fadeaway-orange transition-all duration-300 font-medium text-base px-3 py-1"
            >
              {link.label}
            </a>
          ))}
          <a
            href="/audit-request"
            class="bg-fadeaway-orange/10 border border-fadeaway-orange/50 text-fadeaway-orange hover:bg-fadeaway-orange hover:text-black transition-all duration-300 font-bold text-sm px-5 py-2 rounded-xl uppercase tracking-wider shadow-[0_0_15px_rgba(249,115,22,0.15)]"
          >
            See Demo
          </a>
        </div>

        <!-- Social Links (Hidden as per original) -->
        <div class="flex items-center gap-2 hidden">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              class="w-7 h-7 flex items-center justify-center glass-effect hover:bg-fadeaway-orange/20 rounded-lg transition-colors"
              aria-label={social.name}
              set:html={social.icon}
            />
          ))}
        </div>
      </nav>
    </div>
  </div>

  <!-- Mobile Navigation Menu -->
  <nav id="mobile-menu" class="hidden md:hidden absolute top-full left-0 right-0 backdrop-blur-md bg-black/90 border-b border-white/10 shadow-lg transition-all duration-300">
    <div class="flex flex-col items-center gap-2 p-4">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="mobile-nav-link text-neutral-50 hover:text-fadeaway-orange transition-all duration-300 font-medium text-base px-3 py-2 w-full text-center"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/audit-request"
        class="mobile-nav-link mt-2 bg-fadeaway-orange/10 border border-fadeaway-orange/50 text-fadeaway-orange hover:bg-fadeaway-orange hover:text-black transition-all duration-300 font-bold text-sm px-5 py-2.5 rounded-xl uppercase tracking-wider w-full text-center shadow-[0_0_15px_rgba(249,115,22,0.15)]"
      >
        See Demo
      </a>
    </div>
  </nav>
</header>

<script>
  const header = document.getElementById('main-header');
  const desktopNavContainer = document.getElementById('desktop-nav-container');
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuPathOpen = document.querySelector('.menu-path-open');
  const menuPathClose = document.querySelector('.menu-path-close');
  const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

  // Handle Scroll
  function handleScroll() {
    const isScrolled = window.scrollY > 100;
    if (header && desktopNavContainer) {
      if (isScrolled) {
        header.classList.add('md:top-[5px]', 'md:py-2');
        header.classList.remove('md:top-0');
        desktopNavContainer.classList.add('bg-black/60', 'py-1.5');
        desktopNavContainer.classList.remove('py-2');
      } else {
        header.classList.add('md:top-0', 'md:py-2');
        header.classList.remove('md:top-[5px]');
        desktopNavContainer.classList.add('py-2');
        desktopNavContainer.classList.remove('bg-black/60', 'py-1.5');
      }
    }
  }

  // Handle Mobile Menu Toggle
  function toggleMenu() {
    const isExpanded = !mobileMenu?.classList.contains('hidden');
    if (mobileMenu && menuPathOpen && menuPathClose) {
      if (isExpanded) {
        mobileMenu.classList.add('hidden');
        mobileMenu.classList.remove('flex', 'flex-col');
        menuPathOpen.classList.remove('hidden');
        menuPathClose.classList.add('hidden');
      } else {
        mobileMenu.classList.remove('hidden');
        mobileMenu.classList.add('flex', 'flex-col');
        menuPathOpen.classList.add('hidden');
        menuPathClose.classList.remove('hidden');
      }
    }
  }

  // Close menu on link click
  mobileNavLinks.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      mobileMenu?.classList.remove('flex', 'flex-col');
      menuPathOpen?.classList.remove('hidden');
      menuPathClose?.classList.add('hidden');
    });
  });

  window.addEventListener('scroll', handleScroll);
  menuToggle?.addEventListener('click', toggleMenu);

  // Run on load
  handleScroll();
</script>
