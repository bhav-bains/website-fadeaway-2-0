---
import Badge from "./Badge.astro";

export interface Testimonial {
    headline: string;
    quote: string;
    author: string;
    role: string;
    stars?: number;
}

interface Props {
    eyebrow?: string;
    title?: string;
    testimonials: Testimonial[];
}

const {
    eyebrow = "CLIENT SUCCESS",
    title = "Don't just take our word for it.",
    testimonials,
} = Astro.props;
---

<section class="section-padding bg-[#0A0A0B] border-t border-white/5 relative overflow-hidden" id="success-stories">
    {/* Decorative Elements */}
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(45,212,191,0.03)_0%,transparent_100%)] pointer-events-none"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-fadeaway-teal/5 blur-[120px] rounded-full pointer-events-none -z-10"></div>

    <div class="container-max relative z-10 w-full">
        <div class="text-center mb-12 md:mb-16 animate-fade-in">
            {eyebrow && (
                <div class="mb-4 flex justify-center">
                    <Badge variant="primary">{eyebrow}</Badge>
                </div>
            )}
            {title && (
                <h2 class="text-3xl md:text-5xl font-outfit font-bold text-neutral-50 mb-4">{title}</h2>
            )}
        </div>

        {/* Scrollable Container */}
        <div id="testimonial-scroll-container" class="-mx-4 px-4 md:mx-0 md:px-0 flex gap-4 md:gap-6 overflow-x-auto overscroll-x-contain snap-x snap-mandatory no-scrollbar pb-8 md:grid md:grid-cols-3 md:overflow-visible w-screen md:w-full">
            {testimonials.map((testimonial) => (
                <div class="flex-shrink-0 w-[85vw] md:w-auto snap-center bg-[#131315] border border-white/10 rounded-2xl p-6 md:p-8 flex flex-col shadow-[0_0_30px_rgba(0,0,0,0.5)] border-t-2 border-t-fadeaway-orange animate-fade-in relative hover:border-white/20 transition-all duration-300">
                    
                    {/* Stars */}
                    <div class="flex gap-1 mb-6">
                        {Array.from({ length: testimonial.stars ?? 5 }).map(() => (
                            <span class="text-fadeaway-orange text-lg drop-shadow-[0_0_8px_rgba(249,115,22,0.4)]">★</span>
                        ))}
                    </div>

                    {/* Headline */}
                    <h3 class="text-xl md:text-2xl font-outfit font-bold text-neutral-50 mb-4 leading-snug">
                        "{testimonial.headline}"
                    </h3>

                    {/* Quote */}
                    <div class="relative flex-1 mb-8">
                        <span class="absolute -top-4 -left-2 text-4xl text-white/5 font-serif pointer-events-none">"</span>
                        <p class="text-sm md:text-base text-neutral-300 leading-relaxed italic font-dm-sans opacity-90 relative z-10">
                            {testimonial.quote}
                        </p>
                    </div>

                    {/* Attribution (Hidden for now based on user request) */}
                    <div class="pt-6 border-t border-white/5 mt-auto hidden">
                        <span class="text-fadeaway-teal font-bold block">{testimonial.author}</span>
                        <span class="text-neutral-500 text-xs uppercase tracking-widest mt-1 block">{testimonial.role}</span>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<script>
    function setupTestimonialScroll() {
        const container = document.getElementById('testimonial-scroll-container');
        if (!container) return;

        let autoScrollInterval: ReturnType<typeof setInterval> | undefined;
        
        const startAutoScroll = () => {
            // Only auto-scroll on screens smaller than md (768px)
            if (window.innerWidth >= 768) return;
            
            // Clear any existing interval to prevent runaway speeds
            if (autoScrollInterval) clearInterval(autoScrollInterval);

            autoScrollInterval = setInterval(() => {
                // Check if scrolled to the absolute right edge
                // We leave a tiny 10px buffer for precision bugs in browser scrollWidths
                if (container.scrollLeft + container.clientWidth >= container.scrollWidth - 10) {
                    // Loop back to the start smoothly
                    container.scrollTo({ left: 0, behavior: 'smooth' });
                } else {
                    // Advance right by ~85vw (which is the width of one card from our Tailwind classes)
                    const scrollAmount = window.innerWidth * 0.85;
                    container.scrollBy({ left: scrollAmount, behavior: 'smooth' });
                }
            }, 3000);
        };

        const stopAutoScroll = () => {
            if (autoScrollInterval) clearInterval(autoScrollInterval);
        };

        // Initialize
        startAutoScroll();

        // Pause auto-scroll immediately if the user touches the screen to avoid fighting their thumb
        container.addEventListener('touchstart', stopAutoScroll, { passive: true });
        
        // Handle window re-sizes dynamically
        window.addEventListener('resize', () => {
            stopAutoScroll();
            startAutoScroll();
        });
    }

    // Run setup immediately since Astro scripts are deferred modules
    setupTestimonialScroll();
    
    // Support Astro View Transitions API if used anywhere on the site
    document.addEventListener('astro:page-load', setupTestimonialScroll);
</script>
