---
interface Pillar {
    title: string;
    copy: string;
    icon?: string;
    image?: ImageMetadata;
}

interface Props {
    title?: string;
    pillars: Pillar[];
}

const { title = "The 3 Pillars of Success", pillars } = Astro.props;
import ServiceCard from "./ServiceCard.astro";
---

<section class="section-padding bg-fadeaway-darker">
    <div class="container-max">
        {
            title && (
                <div class="mb-16 text-center animate-fade-in">
                    <h2 class="text-3xl md:text-5xl font-outfit font-bold text-neutral-50">
                        {title}
                    </h2>
                </div>
            )
        }

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {
                pillars.map((pillar, index) => (
                    <ServiceCard
                        title={pillar.title}
                        icon={pillar.icon}
                        image={pillar.image}
                    >
                        {pillar.copy}
                    </ServiceCard>
                ))
            }
        </div>

        <div class="mt-16">
            <slot />
        </div>
    </div>
</section>
