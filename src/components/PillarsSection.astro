---
interface Pillar {
    title: string;
    copy: string;
    icon?: string;
}

interface Props {
    title?: string;
    pillars: Pillar[];
}

const { title = "The 3 Pillars of Success", pillars } = Astro.props;
---

<section class="section-padding border-t border-white/5">
    <div class="container-max">
        {
            title && (
                <div class="mb-16 text-center">
                    <h2 class="text-3xl md:text-5xl font-outfit font-bold text-neutral-50">
                        {title}
                    </h2>
                </div>
            )
        }

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {
                pillars.map((pillar, index) => (
                    <div class="glass-dark p-8 md:p-10 hover:bg-white/5 transition-colors duration-500 group">
                        <div class="text- fadeaway-orange mb-6 text-4xl group-hover:scale-110 transition-transform duration-300">
                            {pillar.icon ||
                                (index + 1).toString().padStart(2, "0")}
                        </div>
                        <h3 class="text-2xl font-outfit font-bold text-neutral-50 mb-4">
                            {pillar.title}
                        </h3>
                        <p class="text-neutral-400 leading-relaxed">
                            {pillar.copy}
                        </p>
                    </div>
                ))
            }
        </div>
    </div>
</section>
