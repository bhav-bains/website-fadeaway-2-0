---
import { Image } from "astro:assets";
import Card from "./Card.astro";
import Badge from "./Badge.astro";

interface Props {
    eyebrow?: string;
    title: string;
    description?: string;
    image?: ImageMetadata;
    icon?: string;
    href?: string;
}

const { eyebrow, title, description, image, icon, href } = Astro.props;
const Wrapper = href ? "a" : "div";
---

<Wrapper href={href} class="group block h-full">
    <Card
        variant="glass"
        className="h-full flex flex-col relative overflow-hidden !p-0 border border-white/5 transition-all duration-500 hover:shadow-[0_0_30px_rgba(45,212,191,0.1)]"
    >
        {/* Media Section (Image or Icon) */}
        <div
            class="relative h-64 overflow-hidden bg-white/5 flex items-center justify-center"
        >
            <div
                class="absolute inset-0 bg-fadeaway-teal/20 opacity-0 group-hover:opacity-100 transition-opacity duration-700 blur-3xl"
            >
            </div>

            {
                image && (
                    <Image
                        src={image}
                        alt={title}
                        width={800}
                        height={512}
                        quality="high"
                        class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out z-10"
                    />
                )
            }

            {
                icon && (
                    <span class="text-6xl drop-shadow-[0_0_15px_rgba(249,115,22,0.4)] transform group-hover:scale-110 transition-transform duration-300 z-10">
                        {icon}
                    </span>
                )
            }
        </div>

        {/* Content Section */}
        <div class="p-6 flex flex-col flex-1 bg-fadeaway-graphite/40">
            {
                eyebrow && (
                    <div class="mb-2">
                        <Badge variant="primary">{eyebrow}</Badge>
                    </div>
                )
            }
            <h3
                class="text-xl font-outfit font-bold text-neutral-50 mb-2 group-hover:text-fadeaway-teal transition-colors"
            >
                {title}
            </h3>
            <div class="text-neutral-400 text-sm leading-relaxed mb-4 flex-1">
                <slot />
            </div>

            {
                href && (
                    <div class="mt-auto pt-1 flex items-center text-fadeaway-teal text-sm font-medium group-hover:translate-x-1 transition-transform duration-300">
                        See Details <span class="ml-1">→</span>
                    </div>
                )
            }
        </div>
    </Card>
</Wrapper>
