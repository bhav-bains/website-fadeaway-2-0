---
import Card from "./Card.astro";
import Badge from "./Badge.astro";

interface Props {
  title?: string;
  subtitle?: string;
  eyebrow?: string;
}

const {
  title = "Core Offerings & Services",
  subtitle = "High-performance digital products engineered strictly for growth, visibility, and seamless conversions.",
  eyebrow = "SERVICES"
} = Astro.props;

const services = [
  {
    title: "Audit & Growth Strategy",
    icon: "🔍",
    description: "Deep-dive analysis of your current website, local search footprint, and competitors. We identify growth bottlenecks and build a custom, step-by-step roadmap to dominate local rankings."
  },
  {
    title: "Website Redesign",
    icon: "🎨",
    description: "Beautiful, lightning-fast sites built to convert. We replace slow, outdated templates with a high-fidelity, responsive mobile checkout that integrates directly with your business operations."
  },
  {
    title: "Site Migration",
    icon: "📦",
    description: "Moving platforms without losing your rankings. We handle complete domain, content, and link structure migrations cleanly, ensuring zero downtime and fully preserving your search visibility."
  },
  {
    title: "Idea to MVP",
    icon: "🚀",
    description: "Bringing your custom ideas to life. From custom Leads Dashboards to CRM automations, chatbots, and advanced web applications, we engineer scalable systems tailored to your workflow."
  }
];
---

<section class="section-padding bg-fadeaway-dark border-t border-white/5" id="services">
  <div class="container-max">
    {/* Section Header */}
    <div class="mb-12 md:mb-16 text-center animate-fade-in">
      {eyebrow && (
        <div class="flex justify-center mb-4">
          <Badge variant="primary">{eyebrow}</Badge>
        </div>
      )}
      <h2 class="text-4xl md:text-5xl font-outfit font-bold text-neutral-50 mb-4" set:html={title} />
      {subtitle && (
        <p class="text-lg text-neutral-300 max-w-2xl mx-auto">
          {subtitle}
        </p>
      )}
    </div>

    {/* Services Cards Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 max-w-5xl mx-auto">
      {services.map((service) => (
        <Card
          variant="glass"
          className="flex flex-col p-6 md:p-8 rounded-3xl bg-fadeaway-graphite/40 border border-white/10 hover:border-fadeaway-orange/40 transition-all duration-300 hover:shadow-[0_0_30px_rgba(255,107,53,0.08)] group"
        >
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 rounded-2xl bg-fadeaway-orange/10 border border-fadeaway-orange/20 flex items-center justify-center text-fadeaway-orange text-2xl shadow-inner group-hover:scale-110 transition-transform duration-300">
              <span>{service.icon}</span>
            </div>
            <h3 class="text-2xl font-outfit font-bold text-neutral-50 group-hover:text-fadeaway-orange transition-colors">
              {service.title}
            </h3>
          </div>
          <p class="text-neutral-400 text-base leading-relaxed">
            {service.description}
          </p>
        </Card>
      ))}
    </div>
  </div>
</section>
