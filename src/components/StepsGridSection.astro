---
interface Step {
    title: string;
    copy: string;
    icon?: string;
}

interface Props {
    title: string;
    subtitle?: string;
    steps: Step[];
}

const { title, subtitle, steps } = Astro.props;
---

<section class="py-20 md:py-32 relative overflow-hidden bg-fadeaway-dark">
    {/* Setup subtle ambient background */}
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(20,184,166,0.05),transparent_40%)] pointer-events-none"></div>

    <div class="container-max relative z-10">
        <div class="text-center max-w-3xl mx-auto mb-16 md:mb-24 animate-fade-in">
            <h2 class="text-3xl md:text-5xl lg:text-[56px] font-outfit font-bold text-neutral-50 mb-6 leading-[1.2]">
                {title}
            </h2>
            {subtitle && (
                <p class="text-lg md:text-xl text-neutral-400 leading-relaxed font-dm-sans">
                    {subtitle}
                </p>
            )}
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
            {steps.map((step, index) => (
                <div class="relative bg-gradient-to-br from-[#18181A] to-[#0D0D0F] border border-white/5 rounded-xl p-5 md:p-5 overflow-hidden">
                    
                    {/* Big background number watermark */}
                    <span class="absolute -top-3 -right-2 text-[80px] leading-none font-outfit font-black text-white/[0.02] pointer-events-none select-none">
                        0{index + 1}
                    </span>

                    {/* Step Content */}
                    <div class="relative z-10">
                        <div class="w-8 h-8 rounded-lg bg-fadeaway-teal/10 border border-fadeaway-teal/20 flex items-center justify-center text-fadeaway-teal mb-3 shadow-inner">
                            {step.icon ? (
                                <span class="flex items-center justify-center [&>svg]:w-4 [&>svg]:h-4" set:html={step.icon} />
                            ) : (
                                <span class="font-bold text-base">{index + 1}</span>
                            )}
                        </div>
                        <h3 class="text-xl font-outfit font-bold text-neutral-50 mb-1.5 leading-snug">
                            {step.title}
                        </h3>
                        <p class="text-base text-neutral-400 leading-relaxed">
                            {step.copy}
                        </p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
