---
import Button from "./Button.astro";
import Badge from "./Badge.astro";
import Card from "./Card.astro";
---

<section class="section-padding bg-fadeaway-dark border-t border-white/5 relative overflow-hidden" id="labs">
  {/* Developer Glow Accent */}
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="absolute -top-40 -left-40 w-96 h-96 rounded-full bg-fadeaway-orange/5 blur-[120px]"></div>
    <div class="absolute -bottom-40 -right-40 w-96 h-96 rounded-full bg-fadeaway-teal/5 blur-[120px]"></div>
  </div>

  <div class="container-max relative z-10">
    {/* Section Header */}
    <div class="mb-12 md:mb-16 text-center animate-fade-in">
      <div class="flex justify-center mb-4">
        <Badge variant="primary">FADEAWAY LABS</Badge>
      </div>
      <h2 class="text-4xl md:text-5xl font-outfit font-bold text-neutral-50 mb-4">
        From Idea to MVP.<br/>Custom Software Built for Growth.
      </h2>
      <p class="text-lg text-neutral-300 max-w-2xl mx-auto">
        Fadeaway Labs is our custom engineering sandbox. We help startups and growth-minded brands design, prototype, and build custom web applications, integrations, and automated digital systems.
      </p>
    </div>

    {/* Capability Cards Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 max-w-5xl mx-auto mb-16">
      {/* Card 1 */}
      <Card variant="glass" className="flex flex-col p-6 md:p-8 rounded-3xl bg-fadeaway-graphite/40 border border-white/10 hover:border-fadeaway-orange/40 transition-all duration-300 hover:shadow-[0_0_30px_rgba(255,107,53,0.06)] group">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-12 h-12 rounded-2xl bg-fadeaway-orange/10 border border-fadeaway-orange/20 flex items-center justify-center text-fadeaway-orange shadow-inner group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-2xl font-outfit font-bold text-neutral-50 group-hover:text-fadeaway-orange transition-colors">
            Custom Web Apps & SaaS
          </h3>
        </div>
        <p class="text-neutral-400 text-base leading-relaxed">
          Need more than a standard website? We build custom customer portals, SaaS dashboards, booking software, and backend systems structured specifically for your operational workflows.
        </p>
      </Card>

      {/* Card 2 */}
      <Card variant="glass" className="flex flex-col p-6 md:p-8 rounded-3xl bg-fadeaway-graphite/40 border border-white/10 hover:border-fadeaway-teal/40 transition-all duration-300 hover:shadow-[0_0_30px_rgba(0,191,165,0.06)] group">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-12 h-12 rounded-2xl bg-fadeaway-teal/10 border border-fadeaway-teal/20 flex items-center justify-center text-fadeaway-teal shadow-inner group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
          </div>
          <h3 class="text-2xl font-outfit font-bold text-neutral-50 group-hover:text-fadeaway-teal transition-colors">
            Automations & Integrations
          </h3>
        </div>
        <p class="text-neutral-400 text-base leading-relaxed">
          Connect your CRM, email databases, booking software, and internal tools. We design secure backend API integrations and custom serverless logic to automate manual tasks.
        </p>
      </Card>

      {/* Card 3 */}
      <Card variant="glass" className="flex flex-col p-6 md:p-8 rounded-3xl bg-fadeaway-graphite/40 border border-white/10 hover:border-fadeaway-orange/40 transition-all duration-300 hover:shadow-[0_0_30px_rgba(255,107,53,0.06)] group">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-12 h-12 rounded-2xl bg-fadeaway-orange/10 border border-fadeaway-orange/20 flex items-center justify-center text-fadeaway-orange shadow-inner group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
          </div>
          <h3 class="text-2xl font-outfit font-bold text-neutral-50 group-hover:text-fadeaway-orange transition-colors">
            AI Chatbots & Qualified Leads
          </h3>
        </div>
        <p class="text-neutral-400 text-base leading-relaxed">
          Qualify search leads 24/7. We integrate custom AI assistants, conversational chatbots, and automated follow-ups trained on your specific services and business information.
        </p>
      </Card>

      {/* Card 4 */}
      <Card variant="glass" className="flex flex-col p-6 md:p-8 rounded-3xl bg-fadeaway-graphite/40 border border-white/10 hover:border-fadeaway-teal/40 transition-all duration-300 hover:shadow-[0_0_30px_rgba(0,191,165,0.06)] group">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-12 h-12 rounded-2xl bg-fadeaway-teal/10 border border-fadeaway-teal/20 flex items-center justify-center text-fadeaway-teal shadow-inner group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h3 class="text-2xl font-outfit font-bold text-neutral-50 group-hover:text-fadeaway-teal transition-colors">
            Performance Dashboards
          </h3>
        </div>
        <p class="text-neutral-400 text-base leading-relaxed">
          Stop guessing your ROI. We build secure analytics dashboards tracking your exact search rankings, client booking conversion rates, and revenue impact in one unified system.
        </p>
      </Card>
    </div>

    {/* Introductory CTA Box */}
    <div class="max-w-4xl mx-auto bg-fadeaway-graphite/30 border border-white/10 rounded-3xl p-8 md:p-12 text-center relative overflow-hidden">
      {/* Background neon gradients */}
      <div class="absolute inset-0 bg-gradient-to-tr from-fadeaway-orange/5 to-fadeaway-teal/5 pointer-events-none"></div>
      
      <h3 class="text-2xl md:text-3xl font-outfit font-bold text-neutral-50 mb-4 relative z-10">
        Have a Custom Project in Mind?
      </h3>
      <p class="text-neutral-300 text-base md:text-lg max-w-2xl mx-auto mb-8 relative z-10 leading-relaxed">
        Let’s design the architecture, establish the MVP features, and map out a step-by-step roadmap to bring your custom software idea to life.
      </p>
      
      <div class="relative z-10">
        <a href="/contact">
          <Button variant="primary" size="lg">Let's Build Your MVP</Button>
        </a>
      </div>
    </div>
  </div>
</section>
